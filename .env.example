
# --- Environment ---
APP_ENV=production
APP_MODE=paper
LOG_LEVEL=INFO
TIMEZONE=Europe/Amsterdam
PYTHONUNBUFFERED=1

# --- Exchange ---
BITGET_BASE_URL=https://api.bitget.com
BITGET_API_KEY=your_api_key_here
BITGET_API_SECRET=your_api_secret_here
BITGET_API_PASSPHRASE=your_api_passphrase_here
BITGET_LOCALE=en-US

# --- Product / Market ---
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_MARGIN_COIN=USDT
BITGET_DEFAULT_GRANULARITY=15m
BITGET_CONFIRMATION_GRANULARITY=1H
BITGET_CANDLE_LIMIT=200
BITGET_CONTRACT_CACHE_TTL_SEC=180
BITGET_RATE_LIMIT_MIN_INTERVAL_MS=120
BITGET_RATE_LIMIT_429_COOLDOWN_SEC=5.0
BITGET_MAX_REQUEST_RETRIES=3
BITGET_RETRY_BACKOFF_SECONDS=1.25
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT,NEARUSDT,WIFUSDT,DOGEUSDT,AVAXUSDT,LINKUSDT,OPUSDT,ARBUSDT,INJUSDT,FETUSDT,ADAUSDT,BNBUSDT,APTUSDT,ATOMUSDT,LDOUSDT,UNIUSDT,TIAUSDT,ENAUSDT,BCHUSDT,RUNEUSDT,SEIUSDT,ICPUSDT,AAVEUSDT,XLMUSDT,TRXUSDT,FILUSDT
ALLOW_AUTO_WATCHLIST_REFRESH=true
MIN_USDT_VOLUME_24H=10000000
MIN_CHANGE_PCT_24H_ABS=1.5
MAX_SYMBOLS=28
STRATEGY_DEBUG_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,NEARUSDT,WIFUSDT,AVAXUSDT,LINKUSDT,OPUSDT,FETUSDT,SEIUSDT,AAVEUSDT,FILUSDT
ENABLE_SHORTS=true

# --- Runner ---
SCAN_ON_START=true
SCAN_LOOP_ENABLED=true
SCAN_INTERVAL_SEC=60

# --- Strategy ---
SWEEP_PIVOT_LOOKBACK=12
SWEEP_RECENT_BARS=6
SWEEP_RECLAIM_TOLERANCE_BPS=12
MIN_SWEEP_DISPLACEMENT_PCT=0.12
MIN_SWEEP_VOLUME_RATIO=1.15
STRATEGY_CANDIDATE_LIMIT=5
STRATEGY_SCORE_GO_THRESHOLD=70
STRATEGY_SCORE_WATCH_THRESHOLD=60
MOMENTUM_MIN_VOLUME_RATIO=1.2
MOMENTUM_BREAKDOWN_MIN_VOLUME_RATIO=1.2

# --- Risk / Planner ---
ACCOUNT_EQUITY_USDT=100
ACCOUNT_BALANCE_USDT=100
ACCOUNT_RISK_PER_TRADE_PCT=0.75
DEFAULT_LEVERAGE=5
MAX_LEVERAGE=5
MAX_OPEN_POSITIONS=2
MAX_DAILY_LOSS_PCT=1.5
HARD_DAILY_STOP_PCT=2.0
WEEKLY_FREEZE_LOSS_PCT=7.0
PLANNER_LADDER_STEPS=3
PLANNER_STOP_BUFFER_BPS=8
PLANNER_TP1_R_MULTIPLE=1.2
PLANNER_TP2_R_MULTIPLE=1.8
PLANNER_TP3_R_MULTIPLE=2.6
PLANNER_MIN_RR=1.2
PLANNER_MIN_LIVE_NOTIONAL_USDT=10
SYMBOL_COOLDOWN_MINUTES=30
BREAK_EVEN_FEE_BUFFER_PCT=0.10

# --- Execution ---
EXECUTION_ENABLED=false
EXECUTION_MODE=DRY_RUN
EXECUTION_REQUIRE_CONFIRMATION=true
EXECUTION_CONFIRM_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,NEARUSDT,WIFUSDT,DOGEUSDT,AVAXUSDT,LINKUSDT,OPUSDT,ARBUSDT,INJUSDT,FETUSDT,ADAUSDT,BNBUSDT,APTUSDT,ATOMUSDT,LDOUSDT,UNIUSDT,TIAUSDT,ENAUSDT,BCHUSDT,RUNEUSDT,SEIUSDT,ICPUSDT,AAVEUSDT,XLMUSDT,TRXUSDT,FILUSDT
EXECUTION_MAX_PER_CYCLE=1
EXECUTION_PLAN_LIMIT=3

# --- Position Manager ---
POSITION_MANAGER_ENABLED=true
POSITION_SYNC_ON_START=true
POSITION_LOOP_ENABLED=true
POSITION_CHECK_INTERVAL_SEC=15
MOVE_STOP_TO_BE_AFTER_TP1=true
TP1_CLOSE_PCT=40
TP2_CLOSE_PCT=30
TP3_CLOSE_PCT=30

# --- Dashboard ---
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501
DASHBOARD_DEBUG=false
# The dashboard can start/stop the live bot and binds to 0.0.0.0 (your whole
# network) -- set a real password here. If left unset, a random one-time
# password is generated on every dashboard start and printed to its log.
DASHBOARD_PASSWORD=
# Optional: keeps browser sessions valid across dashboard restarts. If unset,
# a random key is generated per-run (you'll just need to log in again after
# a restart).
DASHBOARD_SECRET_KEY=
